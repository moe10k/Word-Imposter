# Copy this file to .env and provide real secrets before running locally.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-nano"
APP_URL="http://localhost:3000"

# Preferred for Heroku and managed MySQL providers:
DATABASE_URL=""
JAWSDB_URL=""
CLEARDB_DATABASE_URL=""
STACKHERO_MYSQL_DATABASE_URL=""

# Fallback split config when no connection URL is available:
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="word_imposter"
DB_USER="root"
DB_PASSWORD=""
DB_CONNECTION_LIMIT="10"
DB_SSL="false"
DB_SSL_REJECT_UNAUTHORIZED="true"
DB_SSL_CA_BASE64=""

SESSION_SECRET=""
SESSION_TTL_DAYS="7"
AUTH_COOKIE_NAME="word_imposter_session"

