{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && node scripts/build-server.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "db:setup": "tsx scripts/migrate.ts",
    "lint": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "smoke:prod": "npm run build && node scripts/smoke-production.mjs",
    "start": "node build/server.js",
    "test": "node --test --experimental-strip-types tests/auth.test.ts tests/db.test.ts tests/migrations.test.ts"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "mysql2": "^3.15.1",
    "motion": "^12.23.24",
    "openai": "^6.32.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.10",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
